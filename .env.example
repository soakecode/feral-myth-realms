# ============================================================
# Feral Myth: Realms — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real keys to version control.
# ============================================================

# ---- CLIENT (Vite prefix required for browser access) ----

# Supabase project URL (find in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key — safe to expose in browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Colyseus game server URL
VITE_GAME_SERVER_URL=ws://localhost:2567

# ---- SERVER (Node.js — never exposed to browser) ----

# Server listen port
PORT=2567

# Environment: development | production
NODE_ENV=development

# Supabase URL (same as client)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (for public-access calls from server if needed)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER put this in client code
# Used only in server to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Allowed CORS origin for the game client
CLIENT_ORIGIN=http://localhost:5173
